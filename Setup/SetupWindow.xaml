<Window x:Class="InventorAutoSave.Setup.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Installation &#x2014; InventorAutoSave &#x2014; v1.0.0 &#x2014; R 2026-04-08 &#x2014; By Mohammed Amine Elgalai &#x2014; XNRGY CLIMATE SYSTEMS ULC"
        Width="780" Height="750"
        MinWidth="780" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#1a1a2e"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>

        <Style x:Key="FeatureCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#2d2d44"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="0,6,0,6"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="BorderBrush" Value="#4361ee"/>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4cc9f0"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>

        <Style x:Key="FeatureTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#f8f9fa"/>
        </Style>

        <Style x:Key="FeatureItemStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#4ade80"/>
            <Setter Property="Margin" Value="12,3,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="FeatureDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>

        <Style x:Key="HighlightCardStyle" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#2d2d44" Offset="0"/>
                        <GradientStop Color="#1e3a5f" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="0,6,0,6"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="BorderBrush" Value="#00bcd4"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4361ee"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="22,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4cc9f0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3a0ca3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#333344"/>
                                <Setter Property="Foreground" Value="#555566"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2d2d44"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#4361ee"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3a3a55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OptionCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="LogText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4ade80"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

    </Window.Resources>

    <Border Background="#1a1a2e" CornerRadius="10"
            BorderBrush="#4361ee" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="90"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- BARRE TITRE CUSTOM (draggable)                         -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Border Grid.Row="0" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0f0f23" Offset="0"/>
                        <GradientStop Color="#1a1a3e" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="&#x1F4BE;" FontSize="15" Foreground="White"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="InventorAutoSave &#x2014; Installation"
                                   Foreground="#9ca3af" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="BtnClose" Content="&#x2715;"
                            Width="44" Height="44" BorderThickness="0" FontSize="13"
                            Cursor="Hand" Click="BtnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#6b7280"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="0,10,0,0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#C42B1C"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- HEADER GRADIENT XEAT                                    -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Border Grid.Row="1" Padding="22,0" BorderBrush="#2d2d44" BorderThickness="0,0,0,2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E3A5F" Offset="0"/>
                        <GradientStop Color="#162D4A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#4361ee" CornerRadius="10"
                            Width="54" Height="54" Margin="0,0,16,0">
                        <TextBlock Text="&#x1F4BE;" FontSize="28" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="InventorAutoSave" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock FontSize="13" Margin="0,4,0,0">
                            <Run Text="&#x1F4A1;" Foreground="#FFD700"/>
                            <Run Text=" Sauvegarde automatique silencieuse pour Autodesk Inventor" Foreground="#e0e0e0"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- CONTENU CENTRAL                                         -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Grid Grid.Row="2">

                <!-- ─── PANEL 1 : BIENVENUE ─── -->
                <ScrollViewer x:Name="PanelWelcome" Visibility="Visible"
                              VerticalScrollBarVisibility="Auto" Padding="4,0">
                    <StackPanel Margin="22,10,22,10">

                        <TextBlock Text="&#x25BA; Bienvenue dans l'assistant d'installation"
                                   Style="{StaticResource SectionHeaderStyle}"/>

                        <Border Style="{StaticResource HighlightCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FeatureTitleStyle}"
                                           Text="Sauvegarde intelligente &#x2014; zero interruption"/>
                                <TextBlock Style="{StaticResource FeatureDescriptionStyle}">
                                    <Run Text="InventorAutoSave surveille vos documents Inventor en arriere-plan et les sauvegarde automatiquement "/>
                                    <Run Text="sans aucune popup de confirmation." FontWeight="SemiBold" Foreground="#4cc9f0"/>
                                    <Run Text=" L'application se loge dans la barre de notification Windows."/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="&#x2728; Fonctionnalites principales" Style="{StaticResource SectionHeaderStyle}"/>

                        <Border Style="{StaticResource FeatureCardStyle}">
                            <StackPanel>
                                <TextBlock Text="&#x1F4BE; Save Active (recommande)" Style="{StaticResource FeatureTitleStyle}"/>
                                <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                           Text="Sauvegarde le document actif ET tous ses composants modifies (pieces, sous-assemblages). Rapide et precis."/>
                                <TextBlock Style="{StaticResource FeatureItemStyle}" Text="&#x2705; Detection recursive des composants dirty"/>
                                <TextBlock Style="{StaticResource FeatureItemStyle}" Text="&#x2705; Ordre optimal : pieces &#x2192; assemblages &#x2192; dessins"/>
                                <TextBlock Style="{StaticResource FeatureItemStyle}" Text="&#x2705; Zero popup, zero interruption"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource FeatureCardStyle}">
                            <StackPanel>
                                <TextBlock Text="&#x1F4C2; Save All (complet)" Style="{StaticResource FeatureTitleStyle}"/>
                                <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                           Text="Sauvegarde tous les documents ouverts dans Inventor, qu'ils soient lies ou non au document actif."/>
                                <TextBlock Style="{StaticResource FeatureItemStyle}" Text="&#x2705; Tous les fichiers ouverts en une passe"/>
                                <TextBlock Style="{StaticResource FeatureItemStyle}" Text="&#x2705; Utile pour sessions multi-projets"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource FeatureCardStyle}">
                            <StackPanel>
                                <TextBlock Text="&#x2699;&#xFE0F; Configuration et persistance" Style="{StaticResource FeatureTitleStyle}"/>
                                <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                           Text="Tous les reglages (intervalle, mode, notifications) sont sauvegardes automatiquement et restaures entre les sessions."/>
                                <TextBlock Style="{StaticResource FeatureItemStyle}" Text="&#x2705; Intervalle : 10 secondes a 30 minutes"/>
                                <TextBlock Style="{StaticResource FeatureItemStyle}" Text="&#x2705; Notifications systray optionnelles"/>
                                <TextBlock Style="{StaticResource FeatureItemStyle}" Text="&#x2705; Demarrage automatique avec Windows (configurable)"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="&#x1F4C1; Dossier d'installation" Style="{StaticResource SectionHeaderStyle}"/>
                        <Border Background="#2d2d44" CornerRadius="8" Padding="14,10"
                                BorderBrush="#4361ee" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4C1; " FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtInstallPath" Foreground="#4cc9f0"
                                           FontSize="12" FontFamily="Consolas" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="&#x2699;&#xFE0F; Options d'installation" Style="{StaticResource SectionHeaderStyle}"/>
                        <Border Style="{StaticResource FeatureCardStyle}">
                            <StackPanel>
                                <CheckBox x:Name="ChkStartup" Style="{StaticResource OptionCheck}" IsChecked="True">
                                    <TextBlock TextWrapping="Wrap" Foreground="#cccccc" FontSize="12">
                                        <Run Text="&#x1F4C5; " Foreground="White"/>
                                        <Run Text="Demarrer automatiquement avec Windows"/>
                                    </TextBlock>
                                </CheckBox>
                                <CheckBox x:Name="ChkLaunch" Style="{StaticResource OptionCheck}" IsChecked="True">
                                    <TextBlock TextWrapping="Wrap" Foreground="#cccccc" FontSize="12">
                                        <Run Text="&#x25BA; " Foreground="White"/>
                                        <Run Text="Lancer InventorAutoSave apres l'installation"/>
                                    </TextBlock>
                                </CheckBox>
                                <CheckBox x:Name="ChkShortcut" Style="{StaticResource OptionCheck}" IsChecked="True">
                                    <TextBlock TextWrapping="Wrap" Foreground="#cccccc" FontSize="12">
                                        <Run Text="&#x1F4CB; " Foreground="White"/>
                                        <Run Text="Creer un raccourci dans le menu Demarrer"/>
                                    </TextBlock>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                        <!-- SECTION DEVELOPPEUR -->
                        <TextBlock Text="&#x1F464; Developpeur" Style="{StaticResource SectionHeaderStyle}"/>
                        <Border Style="{StaticResource FeatureCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Mohammed Amine Elgalai" Style="{StaticResource FeatureTitleStyle}"/>
                                <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                           Text="CAD Designer &amp; Automation Development"/>
                                <TextBlock Style="{StaticResource FeatureDescriptionStyle}"
                                           Text="XNRGY Climate Systems ULC" Margin="0,2,0,0"/>
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Style="{StaticResource FeatureItemStyle}"
                                               Text="&#x1F4E7; mohammedamine.elgalai@xnrgy.com"/>
                                    <TextBlock Style="{StaticResource FeatureItemStyle}"
                                               Text="&#x1F4AC; Teams: @Mohammed Amine Elgalai"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ─── PANEL 2 : PROGRESSION ─── -->
                <StackPanel x:Name="PanelProgress" Margin="22,16,22,10" Visibility="Collapsed">

                    <TextBlock Text="&#x23F3; Installation en cours..."
                               Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,14"/>

                    <TextBlock x:Name="TxtProgressStep" Foreground="#4cc9f0" FontSize="12" Margin="0,0,0,6"/>
                    <Border Background="#2d2d44" CornerRadius="4" Height="8" Margin="0,0,0,18">
                        <Border x:Name="ProgressBar" HorizontalAlignment="Left" CornerRadius="4" Width="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#4361ee" Offset="0"/>
                                    <GradientStop Color="#4cc9f0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>

                    <Border Style="{StaticResource FeatureCardStyle}" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="Step1Icon" Grid.Row="0" Grid.Column="0" Text="&#x2B1C;" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step1Text" Grid.Row="0" Grid.Column="1" Text="Creation du dossier d'installation" Foreground="#9ca3af" FontSize="12" Margin="8,5" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step2Icon" Grid.Row="1" Grid.Column="0" Text="&#x2B1C;" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step2Text" Grid.Row="1" Grid.Column="1" Text="Copie des fichiers de l'application" Foreground="#9ca3af" FontSize="12" Margin="8,5" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step3Icon" Grid.Row="2" Grid.Column="0" Text="&#x2B1C;" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step3Text" Grid.Row="2" Grid.Column="1" Text="Configuration du demarrage Windows" Foreground="#9ca3af" FontSize="12" Margin="8,5" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step4Icon" Grid.Row="3" Grid.Column="0" Text="&#x2B1C;" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step4Text" Grid.Row="3" Grid.Column="1" Text="Creation des raccourcis" Foreground="#9ca3af" FontSize="12" Margin="8,5" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step5Icon" Grid.Row="4" Grid.Column="0" Text="&#x2B1C;" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step5Text" Grid.Row="4" Grid.Column="1" Text="Finalisation" Foreground="#9ca3af" FontSize="12" Margin="8,5" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="&#x1F4CB; Journal d'installation"
                               Style="{StaticResource SectionHeaderStyle}" Margin="0,12,0,6"/>
                    <Border Background="#0f0f23" CornerRadius="8" Padding="12,10"
                            BorderBrush="#2d2d44" BorderThickness="1" Height="110">
                        <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="LogPanel"/>
                        </ScrollViewer>
                    </Border>

                </StackPanel>

                <!-- ─── PANEL 3 : SUCCES ─── -->
                <StackPanel x:Name="PanelSuccess" Margin="22,20,22,10"
                            Visibility="Collapsed" HorizontalAlignment="Center">
                    <TextBlock Text="&#x2705;" FontSize="52" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Installation terminee avec succes !"
                               Foreground="White" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="InventorAutoSave est pret a l'utilisation"
                               Foreground="#9ca3af" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <Border Style="{StaticResource FeatureCardStyle}" MaxWidth="450">
                        <StackPanel>
                            <TextBlock x:Name="TxtSuccessInfo1" Style="{StaticResource FeatureItemStyle}" Margin="0,2"/>
                            <TextBlock x:Name="TxtSuccessInfo2" Style="{StaticResource FeatureItemStyle}" Margin="0,2"/>
                            <TextBlock x:Name="TxtSuccessInfo3" Style="{StaticResource FeatureItemStyle}" Margin="0,2"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1e3a5f" CornerRadius="8" Padding="16,12"
                            BorderBrush="#4cc9f0" BorderThickness="1"
                            Margin="0,10,0,0" MaxWidth="450">
                        <TextBlock TextWrapping="Wrap" Foreground="#e0e0e0" FontSize="12"
                                   HorizontalAlignment="Center" TextAlignment="Center">
                            <Run Text="L'application est dans la barre de notification Windows."/>
                            <LineBreak/>
                            <Run Text="Clic droit sur l'icone "/>
                            <Run Text="&#x1F4BE;" FontSize="13"/>
                            <Run Text=" pour acceder aux parametres."/>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- ─── PANEL 4 : ERREUR ─── -->
                <StackPanel x:Name="PanelError" Margin="22,24,22,10"
                            Visibility="Collapsed" HorizontalAlignment="Center">
                    <TextBlock Text="&#x274C;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Erreur lors de l'installation"
                               Foreground="White" FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <Border Background="#2d1b1b" CornerRadius="8" Padding="16,12"
                            BorderBrush="#f87171" BorderThickness="1"
                            Margin="0,12,0,0" MaxWidth="450">
                        <TextBlock x:Name="TxtErrorMessage" Foreground="#f87171"
                                   FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

            </Grid>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- FOOTER - Standard XEAT                                  -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Border Grid.Row="3" CornerRadius="0,0,10,10"
                    BorderBrush="#2d2d44" BorderThickness="0,1,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0f0f23" Offset="0"/>
                        <GradientStop Color="#1a1a3e" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" 
                               Text="Installation &#x2014; XEAT &#x2014; v1.0.0 &#x2014; R 2026-04-08 &#x2014; By Mohammed Amine Elgalai &#x2014; XNRGY CLIMATE SYSTEMS ULC"
                               Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button x:Name="BtnCancel" Grid.Column="1"
                            Style="{StaticResource SecondaryButton}"
                            Content="Annuler" Click="BtnCancel_Click"/>
                    <Button x:Name="BtnInstall" Grid.Column="3"
                            Style="{StaticResource PrimaryButton}"
                            Content="Installer  &#x279C;" Click="BtnInstall_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Border>

</Window>
