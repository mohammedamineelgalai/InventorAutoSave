<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════════
         InventorAutoSave - Dark Theme (Palette XNRGY)
         Auteur: Mohammed Amine Elgalai - XNRGY Climate Systems ULC
         Version: 1.0.0
         
         PALETTE:
         ┌────────────────────────────────────────────────────────┐
         │ #1E1E2E - Fond principal    │ #0078D4 - Bleu accent   │
         │ #252536 - Fond secondaire   │ #00D26A - Vert succes   │
         │ #2D2D44 - Fond input/hover  │ #FF8C00 - Orange warn   │
         │ #2A4A6F - Header            │ #E81123 - Rouge danger  │
         │ #4A7FBF - Bordures          │ #5B9BD5 - Bordure hover │
         └────────────────────────────────────────────────────────┘
         ═══════════════════════════════════════════════════════════════════════════ -->

    <!-- ╔═══════════════════════════════════════════════════════╗ -->
    <!-- ║         SECTION 1: COULEURS DE BASE                   ║ -->
    <!-- ╚═══════════════════════════════════════════════════════╝ -->
    
    <Color x:Key="WindowBgColor">#1E1E2E</Color>
    <Color x:Key="PanelBgColor">#252536</Color>
    <Color x:Key="InputBgColor">#2D2D44</Color>
    <Color x:Key="HeaderBgColor">#2A4A6F</Color>
    <Color x:Key="HoverBgColor">#3D3D56</Color>
    <Color x:Key="BorderColorVal">#4A7FBF</Color>
    <Color x:Key="BorderHoverColorVal">#5B9BD5</Color>
    
    <Color x:Key="AccentBlueColor">#0078D4</Color>
    <Color x:Key="AccentBlueHoverColor">#1E90FF</Color>
    <Color x:Key="AccentGreenColor">#00D26A</Color>
    <Color x:Key="AccentRedColor">#E81123</Color>
    <Color x:Key="AccentOrangeColor">#FF8C00</Color>
    
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#B8C7D6</Color>
    <Color x:Key="TextMutedColor">#90CAF9</Color>
    <Color x:Key="TextDisabledColor">#666666</Color>
    
    <!-- Brushes -->
    <SolidColorBrush x:Key="WindowBg" Color="{StaticResource WindowBgColor}"/>
    <SolidColorBrush x:Key="PanelBg" Color="{StaticResource PanelBgColor}"/>
    <SolidColorBrush x:Key="InputBg" Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="HeaderBg" Color="{StaticResource HeaderBgColor}"/>
    <SolidColorBrush x:Key="HoverBg" Color="{StaticResource HoverBgColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColorVal}"/>
    <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderHoverColorVal}"/>
    
    <SolidColorBrush x:Key="AccentBlue" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="AccentBlueHover" Color="{StaticResource AccentBlueHoverColor}"/>
    <SolidColorBrush x:Key="AccentGreen" Color="{StaticResource AccentGreenColor}"/>
    <SolidColorBrush x:Key="AccentRed" Color="{StaticResource AccentRedColor}"/>
    <SolidColorBrush x:Key="AccentOrange" Color="{StaticResource AccentOrangeColor}"/>
    
    <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMuted" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextDisabled" Color="{StaticResource TextDisabledColor}"/>

    <!-- ╔═══════════════════════════════════════════════════════╗ -->
    <!-- ║      SECTION 2: CONTEXT MENU DARK (TRAY MENU)         ║ -->
    <!-- ║  Template complet pour supprimer le rendu Windows      ║ -->
    <!-- ╚═══════════════════════════════════════════════════════╝ -->

    <!-- Drop shadow defini AVANT les styles qui l'utilisent (requis par StaticResource) -->
    <DropShadowEffect x:Key="MenuDropShadow" Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.6"/>

    <!-- Style ContextMenu sombre -->
    <Style x:Key="DarkContextMenu" TargetType="ContextMenu">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border x:Name="Border" Background="#1E1E2E"
                            BorderBrush="#4A7FBF" BorderThickness="1"
                            CornerRadius="8" Padding="4,6"
                            Effect="{DynamicResource MenuDropShadow}">
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Separator sombre -->
    <Style x:Key="DarkSeparator" TargetType="Separator">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="8,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Background="#3A3A54" Height="1" Margin="8,4"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- MenuItem sombre - TEMPLATE COMPLET pour éviter le rendu par défaut Windows.
         Le rendu natif de WPF pour MenuItem utilise un thème clair avec des 
         lignes blanches (icon column, check column) qu'on ne peut pas supprimer 
         avec de simples Setters. Il FAUT un ControlTemplate complet. -->
    <Style x:Key="DarkMenuItem" TargetType="MenuItem">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid>
                        <Border x:Name="Bg" Background="Transparent"
                                CornerRadius="5" Margin="2,1" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icone / Checkmark -->
                                <Grid Grid.Column="0" Width="20" Margin="0,0,8,0">
                                    <!-- Checkmark visible si IsCheckable et IsChecked -->
                                    <Path x:Name="CheckMark" 
                                          Data="M0,5 L3,8 L8,0" 
                                          Stroke="#00D26A" StrokeThickness="2.5"
                                          Visibility="Collapsed"
                                          VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>

                                <!-- Header text -->
                                <ContentPresenter Grid.Column="1" 
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"/>

                                <!-- Fleche sous-menu -->
                                <Path x:Name="SubMenuArrow" Grid.Column="3"
                                      Data="M0,0 L4,4 L0,8" 
                                      Fill="#B8C7D6" Margin="10,0,0,0"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed"/>
                            </Grid>
                        </Border>

                        <!-- Popup sous-menu -->
                        <Popup x:Name="SubMenuPopup" 
                               IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               Placement="Right" AllowsTransparency="True"
                               Focusable="False" PopupAnimation="Fade"
                               HorizontalOffset="0" VerticalOffset="-4">
                            <Border Background="#1E1E2E" 
                                    BorderBrush="#4A7FBF" BorderThickness="1"
                                    CornerRadius="8" Padding="4,6"
                                    Effect="{DynamicResource MenuDropShadow}">
                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Hover effect avec glow subtil -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#2D2D44"/>
                            <Setter TargetName="Bg" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#0078D4" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#2D2D44"/>
                        </Trigger>

                        <!-- Checkmark pour IsChecked -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                        </Trigger>

                        <!-- Flèche sous-menu -->
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="SubMenuArrow" Property="Visibility" Value="Visible"/>
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#666666"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ╔═══════════════════════════════════════════════════════╗ -->
    <!-- ║      SECTION 3: BOUTONS                               ║ -->
    <!-- ╚═══════════════════════════════════════════════════════╝ -->

    <!-- Bouton principal bleu avec glow hover -->
    <Style x:Key="XnrgyPrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                            BorderBrush="#4A7FBF" BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#1E90FF"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#00BFFF"/>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#00BFFF" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#005A9E"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#4A7FBF"/>
                            <Setter Property="Foreground" Value="#666666"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Bouton intervalle -->
    <Style x:Key="IntervalBtn" TargetType="Button">
        <Setter Property="Background" Value="#2A2A3E"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="0,0,5,5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="#4A7FBF" BorderThickness="1"
                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#3A3A5E"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#5B9BD5"/>
                            <Setter TargetName="Bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#0078D4" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0078D4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ╔═══════════════════════════════════════════════════════╗ -->
    <!-- ║      SECTION 4: TOGGLE SWITCH (ON/OFF moderne)        ║ -->
    <!-- ╚═══════════════════════════════════════════════════════╝ -->

    <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
        <Setter Property="Width" Value="50"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border x:Name="Track" Background="#3A3A54" CornerRadius="13"
                                BorderBrush="#4A7FBF" BorderThickness="1"
                                Width="50" Height="26"/>
                        <Ellipse x:Name="Thumb" Width="20" Height="20"
                                 Fill="#B8C7D6" HorizontalAlignment="Left"
                                 Margin="3,0,0,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="#0078D4"/>
                            <Setter TargetName="Track" Property="BorderBrush" Value="#1E90FF"/>
                            <Setter TargetName="Thumb" Property="Fill" Value="White"/>
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            <Setter TargetName="Track" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#0078D4" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush" Value="#5B9BD5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Toggle button texte (mode de sauvegarde) -->
    <Style x:Key="ToggleBtn" TargetType="ToggleButton">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd" Background="#2A2A3E" BorderBrush="#4A7FBF"
                            BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0D5C0D"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#00D26A"/>
                            <Setter TargetName="Bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#00D26A" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#3A3A5E"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#5B9BD5"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="#107C10"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#00FF7F"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ╔═══════════════════════════════════════════════════════╗ -->
    <!-- ║      SECTION 5: CARDS ET SECTIONS                     ║ -->
    <!-- ╚═══════════════════════════════════════════════════════╝ -->

    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#90CAF9"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="#252538"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="BorderBrush" Value="#4A7FBF"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ╔═══════════════════════════════════════════════════════╗ -->
    <!-- ║      SECTION 6: SCROLLBAR DARK                        ║ -->
    <!-- ╚═══════════════════════════════════════════════════════╝ -->

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="8"/>
    </Style>

</ResourceDictionary>
