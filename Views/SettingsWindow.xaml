<Window x:Class="InventorAutoSave.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:InventorAutoSave.Services"
        Title="{x:Static svc:BuildInfo.SettingsTitle}"
        Width="780" Height="700"
        MinWidth="780" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#12121C"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Icon="/Resources/InventorAutoSave.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- HEADER (style XEAT — solide #2A4A6F + border bottom)    -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#2A4A6F" Padding="20,14"
                BorderBrush="#4A7FBF" BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚙️" Foreground="White" FontSize="26" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Inventor AutoSave — Configuration"
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Sauvegarde automatique des documents Autodesk Inventor — Smart Tools Amine v1.0"
                                   Foreground="#B8D4E8" FontSize="11" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Bouton Info -->
                <Button Grid.Column="1" x:Name="BtnInfo" Click="BtnInfo_Click"
                        Background="#252538" Foreground="White" BorderBrush="#4A7FBF" BorderThickness="1"
                        Padding="10,6" Margin="0,0,10,0" Cursor="Hand"
                        ToolTip="ℹ️ Informations sur l'application">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="InfoBorder" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ℹ️" Foreground="White" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Info" Foreground="White" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="InfoBorder" Property="Background" Value="#333350"/>
                                    <Setter TargetName="InfoBorder" Property="BorderBrush" Value="#6AA0D0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="InfoBorder" Property="Background" Value="#4A7FBF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Status Inventor -->
                <Border Grid.Column="2" Background="#252538" CornerRadius="6" Padding="12,6"
                        BorderBrush="#4A7FBF" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="InventorStatusDot" Width="10" Height="10"
                                 Fill="{Binding InventorStatusColor}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding InventorStatusText}" Foreground="White"
                                   FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- CONTENU PRINCIPAL                                       -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
            <StackPanel>

                <!-- ─── STATUS TEMPS REEL ─── -->
                <TextBlock Text="📊 ETAT EN TEMPS REEL" Style="{StaticResource SectionHeader}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <!-- Ligne 1: Document actif -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Document actif:" Foreground="#B8C7D6" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ActiveDocumentName}"
                                       Foreground="White" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Ligne 2: Etat du fichier (Dirty/Saved) -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Etat fichier:" Foreground="#B8C7D6" FontSize="11" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{Binding ActiveDocSaveStatusColor}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ActiveDocSaveStatus}" Foreground="{Binding ActiveDocSaveStatusColor}"
                                           FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Ligne 3: Documents avec badges -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Documents:" Foreground="#B8C7D6" FontSize="11" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Badge: documents ouverts -->
                                <Border Background="#1E3A5F" CornerRadius="8" Padding="8,2" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📄 " Foreground="White" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding TotalDocuments}" Foreground="#00D4FF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <TextBlock Text=" ouvert(s)" Foreground="#B8C7D6" FontSize="10" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <!-- Badge: documents modifies -->
                                <Border CornerRadius="8" Padding="8,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1A3D1A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DirtyDocuments}" Value="0">
                                                    <Setter Property="Background" Value="#252538"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✏️ " Foreground="White" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DirtyDocuments}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FF8C00"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DirtyDocuments}" Value="0">
                                                            <Setter Property="Foreground" Value="#B8C7D6"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text=" modifie(s)" Foreground="#B8C7D6" FontSize="10" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Ligne 4: Prochain save + Dernier save -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Prochain save:" Foreground="#B8C7D6" FontSize="11" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="⏱️ " Foreground="White" FontSize="11"/>
                                <TextBlock Text="{Binding NextSaveText}" Foreground="#00D4FF" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text=" | Dernier: " Foreground="#B8C7D6" FontSize="11"/>
                                <TextBlock Text="{Binding LastSaveText}" Foreground="#90EE90" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─── AUTOSAVE ON/OFF ─── -->
                <TextBlock Text="⚡ AUTOSAVE" Style="{StaticResource SectionHeader}" Margin="0,8,0,6"/>
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Sauvegarde automatique" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="#B8C7D6" FontSize="11" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <Button Grid.Column="1" Content="{Binding AutoSaveButtonText}"
                                Command="{Binding ToggleAutoSaveCommand}"
                                Background="{Binding AutoSaveButtonColor}"
                                Style="{StaticResource XnrgyPrimaryButton}"
                                VerticalAlignment="Center" MinWidth="120"/>
                    </Grid>
                </Border>

                <!-- ─── SAUVEGARDE MAINTENANT ─── -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="💾 Sauvegarder maintenant" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="Sauvegarde immediate via API COM (silencieuse)" Foreground="#B8C7D6" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1" Content="💾 Sauvegarder"
                                Command="{Binding SaveNowCommand}"
                                Background="#107C10"
                                Style="{StaticResource XnrgyPrimaryButton}"
                                VerticalAlignment="Center" MinWidth="130"/>
                    </Grid>
                </Border>

                <!-- ─── MODE DE SAUVEGARDE ─── -->
                <TextBlock Text="💡 MODE DE SAUVEGARDE" Style="{StaticResource SectionHeader}" Margin="0,8,0,6"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Foreground="#B8C7D6" FontSize="11" Margin="0,0,0,6" TextWrapping="Wrap">
                            <Run Text="SaveActive" FontWeight="SemiBold" Foreground="#00D4FF"/>
                            <Run Text=" = document actif + composants modifies (rapide, sans popup)"/>
                        </TextBlock>
                        <TextBlock Foreground="#B8C7D6" FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap">
                            <Run Text="SaveAll" FontWeight="SemiBold" Foreground="#FFB74D"/>
                            <Run Text=" = tous les documents ouverts (ipt → iam → idw, silencieux via API COM)"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton x:Name="TglSaveActive" Content="💾 Document actif"
                                          Style="{StaticResource ToggleBtn}" Margin="0,0,8,0"
                                          Click="TglSaveActive_Click"/>
                            <ToggleButton x:Name="TglSaveAll" Content="💾 Tous les documents"
                                          Style="{StaticResource ToggleBtn}"
                                          Click="TglSaveAll_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── INTERVALLE ─── -->
                <TextBlock Text="⏱️ INTERVALLE DE SAUVEGARDE" Style="{StaticResource SectionHeader}" Margin="0,8,0,6"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Intervalle actuel: " Foreground="#B8C7D6" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtCurrentInterval" Foreground="#00D4FF"
                                       FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <WrapPanel>
                            <Button Content="10s"   Tag="10"   Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="30s"   Tag="30"   Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="1 min"  Tag="60"   Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="2 min"  Tag="120"  Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="3 min"  Tag="180"  Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="5 min"  Tag="300"  Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="10 min" Tag="600"  Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="15 min" Tag="900"  Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="20 min" Tag="1200" Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="30 min" Tag="1800" Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- ─── OPTIONS ─── -->
                <TextBlock Text="🔧 OPTIONS" Style="{StaticResource SectionHeader}" Margin="0,8,0,6"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <!-- Notifications -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="🔔 Notifications tray" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="Afficher une notification apres chaque sauvegarde" Foreground="#B8C7D6" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtNotifStatus" Grid.Column="1" Foreground="#00D26A" FontSize="11"
                                       FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ToggleButton x:Name="TglNotifications" Grid.Column="2"
                                          Style="{StaticResource ToggleSwitch}"
                                          Click="TglNotifications_Click"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Separator -->
                        <Border Height="1" Background="#3A3A54" Margin="0,0,0,14"/>

                        <!-- Protection calculs -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="🛡️ Protection calculs" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="Differer la sauvegarde si Inventor est en calcul" Foreground="#B8C7D6" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtSafetyStatus" Grid.Column="1" Foreground="#00D26A" FontSize="11"
                                       FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ToggleButton x:Name="TglSafetyChecks" Grid.Column="2"
                                          Style="{StaticResource ToggleSwitch}"
                                          Click="TglSafetyChecks_Click"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- FOOTER / COPYRIGHT BAR (style XEAT)                     -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#1E1E2E" Padding="16,8"
                BorderBrush="#4A7FBF" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock HorizontalAlignment="Left" Foreground="#B8D4E8" FontSize="10" FontWeight="SemiBold"
                           Text=".NET 8 | WPF | API COM Inventor"
                           VerticalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Right" Foreground="#90CAF9" FontSize="10"
                           Text="{x:Static svc:BuildInfo.SettingsTitle}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
