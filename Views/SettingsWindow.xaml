<Window x:Class="InventorAutoSave.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventor AutoSave - Configuration"
        Width="560" Height="680"
        MinWidth="480" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        Background="#12121C"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Icon="/Resources/InventorAutoSave.ico">

    <Window.Resources>

        <!-- Couleurs -->
        <SolidColorBrush x:Key="HeaderBg"    Color="#1E1E2E"/>
        <SolidColorBrush x:Key="SectionBg"   Color="#2A2A3E"/>
        <SolidColorBrush x:Key="CardBg"       Color="#252538"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#4A7FBF"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="White"/>
        <SolidColorBrush x:Key="TextSecond"   Color="#AAAAAA"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#0078D4"/>
        <SolidColorBrush x:Key="GreenConn"    Color="#107C10"/>
        <SolidColorBrush x:Key="RedDisconn"   Color="#E81123"/>

        <!-- Style Section -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#90CAF9"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Style Card -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#252538"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderBrush" Value="#4A7FBF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Style bouton principal -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bouton interval -->
        <Style x:Key="IntervalBtn" TargetType="Button">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="#4A7FBF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,5,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A5E"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#60A0EF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle style (CheckBox sans checkbox) -->
        <Style x:Key="ToggleBtn" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="#2A2A3E" BorderBrush="#4A7FBF"
                                BorderThickness="1" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#107C10"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#20B020"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A5E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Contenu -->
            <RowDefinition Height="Auto"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- HEADER                                                  -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1E1E2E" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Titre -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚙️" Foreground="White" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="Inventor AutoSave" Foreground="White" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="Smart Tools Amine v2.0" Foreground="#90CAF9" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status Inventor (haut droite) -->
                <Border Grid.Column="1" Background="#252538" CornerRadius="6" Padding="12,6"
                        BorderBrush="#4A7FBF" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="InventorStatusDot" Width="10" Height="10"
                                 Fill="{Binding InventorStatusColor}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="⚙️" Foreground="White" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding InventorStatusText}" Foreground="White"
                                   FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- CONTENU PRINCIPAL                                       -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
            <StackPanel>

                <!-- ─── STATUS TEMPS REEL ─── -->
                <TextBlock Text="📊 ETAT EN TEMPS REEL" Style="{StaticResource SectionHeader}"/>
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Document actif -->
                        <TextBlock Grid.Column="0" Grid.Row="0" Text="Document actif:" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock Grid.Column="1" Grid.Row="0" Text="{Binding ActiveDocumentName}"
                                   Foreground="White" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>

                        <!-- Documents -->
                        <TextBlock Grid.Column="0" Grid.Row="1" Text="Documents:" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding DocumentsStatusText}"
                                   Foreground="White" FontSize="11" Margin="0,0,0,4"/>

                        <!-- Prochain save -->
                        <TextBlock Grid.Column="0" Grid.Row="2" Text="Prochain save:" Foreground="#AAAAAA" FontSize="11"/>
                        <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="⏱️ " Foreground="White" FontSize="11"/>
                            <TextBlock Text="{Binding NextSaveText}" Foreground="#00D4FF" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text=" | Dernier: " Foreground="#AAAAAA" FontSize="11"/>
                            <TextBlock Text="{Binding LastSaveText}" Foreground="#90EE90" FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ─── AUTOSAVE ON/OFF ─── -->
                <TextBlock Text="⚡ AUTOSAVE" Style="{StaticResource SectionHeader}" Margin="0,8,0,6"/>
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Sauvegarde automatique" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="#AAAAAA" FontSize="11" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <Button Grid.Column="1" Content="{Binding AutoSaveButtonText}"
                                Command="{Binding ToggleAutoSaveCommand}"
                                Background="{Binding AutoSaveButtonColor}"
                                Style="{StaticResource PrimaryBtn}"
                                VerticalAlignment="Center" MinWidth="120"/>
                    </Grid>
                </Border>

                <!-- ─── SAUVEGARDE MAINTENANT ─── -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="💾 Sauvegarder maintenant" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="Sauvegarde immediate via API COM (silencieuse)" Foreground="#AAAAAA" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1" Content="💾 Sauvegarder"
                                Command="{Binding SaveNowCommand}"
                                Background="#107C10"
                                Style="{StaticResource PrimaryBtn}"
                                VerticalAlignment="Center" MinWidth="130"/>
                    </Grid>
                </Border>

                <!-- ─── MODE DE SAUVEGARDE ─── -->
                <TextBlock Text="💡 MODE DE SAUVEGARDE" Style="{StaticResource SectionHeader}" Margin="0,8,0,6"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,10">
                            <Run Text="SaveActive"/>
                            <Run Text=" = document actif uniquement (plus rapide, sans popup)"/>
                        </TextBlock>
                        <TextBlock Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,10">
                            <Run Text="SaveAll"/>
                            <Run Text=" = tous les documents (ipt → iam → idw, silencieux via API COM)"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton x:Name="TglSaveActive" Content="💾 Document actif"
                                          Style="{StaticResource ToggleBtn}" Margin="0,0,8,0"
                                          Click="TglSaveActive_Click"/>
                            <ToggleButton x:Name="TglSaveAll" Content="💾 Tous les documents"
                                          Style="{StaticResource ToggleBtn}"
                                          Click="TglSaveAll_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── INTERVALLE ─── -->
                <TextBlock Text="⏱️ INTERVALLE DE SAUVEGARDE" Style="{StaticResource SectionHeader}" Margin="0,8,0,6"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Intervalle actuel: " Foreground="#AAAAAA" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtCurrentInterval" Foreground="#00D4FF"
                                       FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <WrapPanel>
                            <Button Content="10s"   Tag="10"   Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="30s"   Tag="30"   Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="1 min"  Tag="60"   Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="2 min"  Tag="120"  Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="3 min"  Tag="180"  Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="5 min"  Tag="300"  Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="10 min" Tag="600"  Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="15 min" Tag="900"  Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="20 min" Tag="1200" Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                            <Button Content="30 min" Tag="1800" Style="{StaticResource IntervalBtn}" Click="IntervalButton_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- ─── OPTIONS ─── -->
                <TextBlock Text="🔧 OPTIONS" Style="{StaticResource SectionHeader}" Margin="0,8,0,6"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <!-- Notifications -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="🔔 Notifications tray" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="Afficher une notification apres chaque sauvegarde" Foreground="#AAAAAA" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleButton x:Name="TglNotifications" Grid.Column="1" Width="60" Height="26"
                                          Style="{StaticResource ToggleBtn}"
                                          Click="TglNotifications_Click"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Protection calculs -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="🛡️ Protection calculs" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="Differer la sauvegarde si Inventor est en calcul" Foreground="#AAAAAA" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleButton x:Name="TglSafetyChecks" Grid.Column="1" Width="60" Height="26"
                                          Style="{StaticResource ToggleBtn}"
                                          Click="TglSafetyChecks_Click"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- FOOTER                                                  -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#1E1E2E" Padding="16,10">
            <Grid>
                <TextBlock HorizontalAlignment="Left" Foreground="#666666" FontSize="10"
                           Text="© 2026 Mohammed Amine Elgalai - XNRGY Climate Systems ULC"
                           VerticalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Right" Foreground="#666666" FontSize="10"
                           Text="v2.0.0 | .NET 8 | API COM Inventor"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
