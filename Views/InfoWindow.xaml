<Window x:Class="InventorAutoSave.Views.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventor AutoSave — Info — v1.0.0 — R 2026-04-09 — By Mohammed Amine Elgalai — XNRGY CLIMATE SYSTEMS ULC"
        Width="780" Height="720"
        MinWidth="700" MinHeight="550"
        WindowStartupLocation="CenterOwner"
        Background="#12121C"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Icon="/Resources/InventorAutoSave.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- HEADER avec Gradient                                    -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Padding="30,25">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E3A5F" Offset="0"/>
                    <GradientStop Color="#162D4A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="⚙️" FontSize="40" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Inventor AutoSave" FontSize="26" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Smart Tools Amine v1.0 — Sauvegarde automatique via API COM"
                                   FontSize="14" Foreground="#90CAF9" Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock FontSize="13" Foreground="#B8C7D6" Margin="0,15,0,0" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="650">
                    <Run Text="Application systray qui sauvegarde automatiquement vos documents Autodesk Inventor via l'API COM. Remplace les scripts manuels par une solution robuste et configurable."/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- CONTENU                                                 -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25,0">
            <StackPanel Margin="0,10,0,20">

                <!-- ─── FONCTIONNALITES ─── -->
                <TextBlock Text="💡 Fonctionnalites" FontSize="16" FontWeight="Bold" Foreground="#4CC9F0" Margin="0,10,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Card 1: Sauvegarde automatique -->
                    <Border Grid.Column="0" Background="#252538" CornerRadius="10" Padding="15" Margin="0,0,6,10"
                            BorderBrush="#0078D4" BorderThickness="0,0,0,3">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#0078D4" CornerRadius="6" Width="35" Height="35" Margin="0,0,10,0">
                                    <TextBlock Text="💾" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Sauvegarde automatique" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Timer configurable de 10s a 30min. Sauvegarde silencieuse via API COM sans popups ni interruptions."
                                       FontSize="12" Foreground="#B8C7D6" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            <TextBlock Text="✅ 10 intervalles disponibles" FontSize="11" Foreground="#4ADE80" Margin="15,6,0,0"/>
                            <TextBlock Text="✅ SaveActive ou SaveAll" FontSize="11" Foreground="#4ADE80" Margin="15,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 2: Connexion COM -->
                    <Border Grid.Column="1" Background="#252538" CornerRadius="10" Padding="15" Margin="6,0,0,10"
                            BorderBrush="#107C10" BorderThickness="0,0,0,3">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#107C10" CornerRadius="6" Width="35" Height="35" Margin="0,0,10,0">
                                    <TextBlock Text="📡" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="API COM Inventor" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Connexion directe a Inventor via oleaut32.dll avec marshaling IDispatch. Detection automatique de l'instance active."
                                       FontSize="12" Foreground="#B8C7D6" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            <TextBlock Text="✅ Reconnexion automatique" FontSize="11" Foreground="#4ADE80" Margin="15,6,0,0"/>
                            <TextBlock Text="✅ Thread STA garanti" FontSize="11" Foreground="#4ADE80" Margin="15,3,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Card 3: Notifications -->
                    <Border Grid.Column="0" Background="#252538" CornerRadius="10" Padding="15" Margin="0,0,6,10"
                            BorderBrush="#FF8C00" BorderThickness="0,0,0,3">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#FF8C00" CornerRadius="6" Width="35" Height="35" Margin="0,0,10,0">
                                    <TextBlock Text="🔔" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Notifications" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Notifications systray configurables apres chaque sauvegarde. Icone dans la barre des taches avec menu contextuel dark."
                                       FontSize="12" Foreground="#B8C7D6" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            <TextBlock Text="✅ Menu contextuel dark complet" FontSize="11" Foreground="#4ADE80" Margin="15,6,0,0"/>
                            <TextBlock Text="✅ Balloon notifications" FontSize="11" Foreground="#4ADE80" Margin="15,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 4: Protection calculs -->
                    <Border Grid.Column="1" Background="#252538" CornerRadius="10" Padding="15" Margin="6,0,0,10"
                            BorderBrush="#E81123" BorderThickness="0,0,0,3">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#E81123" CornerRadius="6" Width="35" Height="35" Margin="0,0,10,0">
                                    <TextBlock Text="🛡️" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Protection calculs" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Detecte quand Inventor est en calcul (simulation, contraintes) et differe la sauvegarde pour eviter les corruptions."
                                       FontSize="12" Foreground="#B8C7D6" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            <TextBlock Text="✅ Detection etat Inventor" FontSize="11" Foreground="#4ADE80" Margin="15,6,0,0"/>
                            <TextBlock Text="✅ Sauvegarde differee" FontSize="11" Foreground="#4ADE80" Margin="15,3,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ─── ARCHITECTURE TECHNIQUE ─── -->
                <TextBlock Text="🔧 Architecture technique" FontSize="16" FontWeight="Bold" Foreground="#4CC9F0" Margin="0,10,0,10"/>

                <Border Background="#252538" CornerRadius="10" Padding="15" Margin="0,0,0,10"
                        BorderBrush="#4A7FBF" BorderThickness="0,0,0,3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Stack" FontWeight="Bold" Foreground="#00D4FF" FontSize="13"/>
                            <TextBlock Text="C# 12 / .NET 8.0" Foreground="White" FontSize="12" Margin="0,5,0,0"/>
                            <TextBlock Text="WPF (Windows)" Foreground="#B8C7D6" FontSize="11" Margin="0,3,0,0"/>
                            <TextBlock Text="COM Interop (oleaut32)" Foreground="#B8C7D6" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Deploiement" FontWeight="Bold" Foreground="#00D4FF" FontSize="13"/>
                            <TextBlock Text="Self-Contained SingleFile" Foreground="White" FontSize="12" Margin="0,5,0,0"/>
                            <TextBlock Text="win-x64 (~68 MB)" Foreground="#B8C7D6" FontSize="11" Margin="0,3,0,0"/>
                            <TextBlock Text="Setup avec exe embarque" Foreground="#B8C7D6" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Patterns" FontWeight="Bold" Foreground="#00D4FF" FontSize="13"/>
                            <TextBlock Text="MVVM (ViewModel)" Foreground="White" FontSize="12" Margin="0,5,0,0"/>
                            <TextBlock Text="ComInvoke Helper" Foreground="#B8C7D6" FontSize="11" Margin="0,3,0,0"/>
                            <TextBlock Text="IDispatch Marshaling" Foreground="#B8C7D6" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ─── DEVELOPPEUR ─── -->
                <TextBlock Text="👤 Developpeur" FontSize="16" FontWeight="Bold" Foreground="#4CC9F0" Margin="0,10,0,10"/>

                <Border Background="#252538" CornerRadius="10" Padding="15" Margin="0,0,0,10"
                        BorderBrush="#4A7FBF" BorderThickness="0,0,0,3">
                    <StackPanel>
                        <TextBlock Text="Mohammed Amine Elgalai" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="CAD Designer &amp; Automation Development" FontSize="13" Foreground="#B8C7D6" Margin="0,4,0,0"/>
                        <TextBlock Text="XNRGY Climate Systems ULC" FontSize="13" Foreground="#B8C7D6" Margin="0,2,0,0"/>
                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="📧 mohammedamine.elgalai@xnrgy.com" FontSize="12" Foreground="#4ADE80" Margin="15,3,0,0"/>
                            <TextBlock Text="💬 Teams: @Mohammed Amine Elgalai" FontSize="12" Foreground="#4ADE80" Margin="15,3,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- FOOTER                                                  -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#252536" Padding="16,8">
            <Grid>
                <TextBlock HorizontalAlignment="Left" Foreground="#90CAF9" FontSize="10"
                           Text="Inventor AutoSave — Info — v1.0.0 — R 2026-04-09 — By Mohammed Amine Elgalai — XNRGY CLIMATE SYSTEMS ULC"
                           VerticalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Right" Foreground="#90CAF9" FontSize="10"
                           Text=".NET 8 | WPF | API COM Inventor"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
